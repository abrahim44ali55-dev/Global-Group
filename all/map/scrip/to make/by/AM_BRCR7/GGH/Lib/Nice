	selfObj.ScreenGui = Create("ScreenGui", {Parent = game.CoreGui, Name = "GGH_V3_Final", ResetOnSpawn = false})
	selfObj.MainFrame = Create("Frame", {Parent = selfObj.ScreenGui, Size = UDim2.new(0, 560, 0, 360), Position = UDim2.new(0.5, -280, 0.5, -180), BackgroundColor3 = CurrentTheme.Main, Active = true, Draggable = true, ClipsDescendants = true}, 12)

	selfObj.Header = Create("Frame", {Parent = selfObj.MainFrame, Size = UDim2.new(1, 0, 0, 45), BackgroundColor3 = Color3.fromRGB(20,20,20)}, 12)
	selfObj.Title = Create("TextLabel", {Parent = selfObj.Header, Size = UDim2.new(1, -120, 1, 0), Position = UDim2.new(0, 15, 0, 0), BackgroundTransparency = 1, Text = title or "GGH HUB V3", TextColor3 = CurrentTheme.Text, Font = Enum.Font.GothamBold, TextSize = 18, TextXAlignment = Enum.TextXAlignment.Left})

	local closeBtn = Create("TextButton", {Parent = selfObj.Header, Size = UDim2.new(0, 35, 0, 35), Position = UDim2.new(1, -40, 0.5, -17), Text = "×", TextColor3 = Color3.fromRGB(255, 50, 50), BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 30})
	local minBtn = Create("TextButton", {Parent = selfObj.Header, Size = UDim2.new(0, 35, 0, 35), Position = UDim2.new(1, -75, 0.5, -17), Text = "−", TextColor3 = CurrentTheme.Text, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 30})

	selfObj.Container = Create("Frame", {Parent = selfObj.MainFrame, Size = UDim2.new(1, 0, 1, -45), Position = UDim2.new(0, 0, 0, 45), BackgroundTransparency = 1})
	
	minBtn.MouseButton1Click:Connect(function()
		local isMin = selfObj.MainFrame.Size.Y.Offset < 100
		minBtn.Text = isMin and "−" or "+"
		selfObj.MainFrame:TweenSize(isMin and UDim2.new(0, 560, 0, 360) or UDim2.new(0, 560, 0, 45), "Out", "Quart", 0.3, true)
		selfObj.Container.Visible = isMin
	end)

	closeBtn.MouseButton1Click:Connect(function()
		local confirm = Create("Frame", {Parent = selfObj.ScreenGui, Size = UDim2.new(0, 280, 0, 130), Position = UDim2.new(0.5, -140, 0.5, -65), BackgroundColor3 = CurrentTheme.Main, BorderSizePixel = 2, BorderColor3 = CurrentTheme.Accent}, 12)
		Create("TextLabel", {Parent = confirm, Size = UDim2.new(1, 0, 0, 60), Text = "Close script and stop all features?", TextColor3 = CurrentTheme.Text, BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, TextSize = 14, TextWrapped = true})
		local y = Create("TextButton", {Parent = confirm, Size = UDim2.new(0, 90, 0, 35), Position = UDim2.new(0.1, 0, 0.65, 0), Text = "YES", BackgroundColor3 = Color3.fromRGB(0, 150, 0), TextColor3 = Color3.fromRGB(255,255,255)}, 8)
		local n = Create("TextButton", {Parent = confirm, Size = UDim2.new(0, 90, 0, 35), Position = UDim2.new(0.55, 0, 0.65, 0), Text = "NO", BackgroundColor3 = Color3.fromRGB(150, 0, 0), TextColor3 = Color3.fromRGB(255,255,255)}, 8)
		y.MouseButton1Click:Connect(function() selfObj.ScreenGui:Destroy() end)
		n.MouseButton1Click:Connect(function() confirm:Destroy() end)
	end)

	selfObj.TabList = Create("ScrollingFrame", {Parent = selfObj.Container, Size = UDim2.new(0, 140, 1, -10), Position = UDim2.new(0, 10, 0, 5), BackgroundTransparency = 1, ScrollBarThickness = 0, CanvasSize = UDim2.new(0,0,0,0)})
	Create("UIListLayout", {Parent = selfObj.TabList, Padding = UDim.new(0, 6)}):GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() selfObj.TabList.CanvasSize = UDim2.new(0,0,0,selfObj.TabList.UIListLayout.AbsoluteContentSize.Y) end)
	selfObj.ContentHolder = Create("Frame", {Parent = selfObj.Container, Size = UDim2.new(1, -170, 1, -10), Position = UDim2.new(0, 160, 0, 5), BackgroundColor3 = Color3.fromRGB(22,22,22), ClipsDescendants = true}, 10)

	selfObj.Tabs = {}
	selfObj.TabButtons = {}
	return selfObj
end

function GGH_Lib:AddTab(name)
	local tabBtn = Create("TextButton", {Parent = self.TabList, Size = UDim2.new(1, -5, 0, 40), Text = name, BackgroundColor3 = Color3.fromRGB(35,35,35), TextColor3 = Color3.fromRGB(180,180,180), Font = Enum.Font.GothamMedium, TextSize = 13}, 8)
	local scroll = Create("ScrollingFrame", {Parent = self.ContentHolder, Size = UDim2.new(1, -12, 1, -12), Position = UDim2.new(0, 6, 0, 6), BackgroundTransparency = 1, Visible = false, ScrollBarThickness = 2})
	Create("UIListLayout", {Parent = scroll, Padding = UDim.new(0, 10)}):GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize = UDim2.new(0,0,0,scroll.UIListLayout.AbsoluteContentSize.Y + 20) end)

	tabBtn.MouseButton1Click:Connect(function()
		for _, s in pairs(self.Tabs) do s.Visible = false end
		for _, b in pairs(self.TabButtons) do b.TextColor3 = Color3.fromRGB(180,180,180) b.BackgroundColor3 = Color3.fromRGB(35,35,35) end
		scroll.Visible = true
		tabBtn.TextColor3 = CurrentTheme.Accent
		tabBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
	end)
	table.insert(self.Tabs, scroll)
	table.insert(self.TabButtons, tabBtn)
	return scroll
end

function GGH_Lib:AddSection(tab, text) Create("TextLabel", {Parent = tab, Size = UDim2.new(1, 0, 0, 25), Text = "— "..text:upper().." —", TextColor3 = CurrentTheme.Accent, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 11, TextTransparency = 0.5}) end

function GGH_Lib:AddButton(tab, text, callback) 
	local btn = Create("TextButton", {Parent = tab, Size = UDim2.new(1, 0, 0, 40), Text = text, BackgroundColor3 = Color3.fromRGB(45,45,45), TextColor3 = CurrentTheme.Text, Font = Enum.Font.GothamSemibold, TextSize = 14}, 8)
	btn.MouseButton1Click:Connect(callback)
end

return GGH_Lib
