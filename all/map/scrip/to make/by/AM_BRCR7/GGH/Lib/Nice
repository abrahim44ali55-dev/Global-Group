-- [[ GGH Library ROYAL SUPREME V2.5 - FLOATING HOME & FIXED UI ]] --
local Lib = {}
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

Lib.Themes = {
    Vape = {Main = Color3.fromRGB(15, 15, 15), Accent = Color3.fromRGB(180, 100, 255), Text = Color3.fromRGB(255, 255, 255), Darker = Color3.fromRGB(10, 10, 10)},
    Blood = {Main = Color3.fromRGB(15, 15, 15), Accent = Color3.fromRGB(255, 45, 45), Text = Color3.fromRGB(255, 255, 255), Darker = Color3.fromRGB(10, 10, 10)}
}

function Lib:CreateWindow(Config)
    local Theme = Lib.Themes[Config.Theme] or Lib.Themes.Vape
    local MainGui = Instance.new("ScreenGui", game.CoreGui)
    MainGui.Name = "GGH_Royal_V25"
    
    -- [ 🏠 الزر العائم بصورة بيت ]
    local FloatingBtn = Instance.new("ImageButton", MainGui)
    FloatingBtn.Size = UDim2.new(0, 50, 0, 50)
    FloatingBtn.Position = UDim2.new(0, 20, 0.5, -25)
    FloatingBtn.BackgroundColor3 = Theme.Main
    FloatingBtn.Image = "rbxassetid://10734951277" -- أيقونة البيت (Home)
    FloatingBtn.ImageColor3 = Theme.Accent
    FloatingBtn.Active = true
    FloatingBtn.Draggable = true -- قابل للسحب في أي مكان بالشاشة
    Instance.new("UICorner", FloatingBtn).CornerRadius = UDim.new(1, 0)
    local FStroke = Instance.new("UIStroke", FloatingBtn); FStroke.Color = Theme.Accent; FStroke.Thickness = 2

    local MainFrame = Instance.new("Frame", MainGui)
    MainFrame.Size = UDim2.new(0, 580, 0, 380); MainFrame.Position = UDim2.new(0.5, -290, 0.5, -190)
    MainFrame.BackgroundColor3 = Theme.Main; MainFrame.ClipsDescendants = true; MainFrame.Visible = true
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 16)
    local MainStroke = Instance.new("UIStroke", MainFrame); MainStroke.Color = Theme.Accent; MainStroke.Thickness = 2

    -- وظيفة الزر العائم (إظهار/إخفاء)
    FloatingBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)

    -- [ نافذة التأكيد ]
    local ConfirmFrame = Instance.new("Frame", MainFrame)
    ConfirmFrame.Size = UDim2.new(0, 280, 0, 140); ConfirmFrame.Position = UDim2.new(0.5, -140, 0.5, -70)
    ConfirmFrame.BackgroundColor3 = Theme.Darker; ConfirmFrame.Visible = false; ConfirmFrame.ZIndex = 200
    Instance.new("UICorner", ConfirmFrame).CornerRadius = UDim.new(0, 12); Instance.new("UIStroke", ConfirmFrame).Color = Theme.Accent
    
    local ConfirmTxt = Instance.new("TextLabel", ConfirmFrame)
    ConfirmTxt.Text = "هل تريد إغلاق السكربت؟"; ConfirmTxt.Size = UDim2.new(1, 0, 0.6, 0); ConfirmTxt.TextColor3 = Theme.Text; ConfirmTxt.BackgroundTransparency = 1; ConfirmTxt.Font = "GothamBold"; ConfirmTxt.TextSize = 16

    local YesBtn = Instance.new("TextButton", ConfirmFrame)
    YesBtn.Text = "نعم"; YesBtn.Size = UDim2.new(0, 100, 0, 35); YesBtn.Position = UDim2.new(0.1, 0, 0.65, 0); YesBtn.BackgroundColor3 = Theme.Accent; YesBtn.TextColor3 = Theme.Main; Instance.new("UICorner", YesBtn)
    
    local NoBtn = Instance.new("TextButton", ConfirmFrame)
    NoBtn.Text = "لا"; NoBtn.Size = UDim2.new(0, 100, 0, 35); NoBtn.Position = UDim2.new(0.55, 0, 0.65, 0); NoBtn.BackgroundColor3 = Color3.fromRGB(40,40,40); NoBtn.TextColor3 = Theme.Text; Instance.new("UICorner", NoBtn)

    -- [ الهيدر والأزرار العلوية ]
    local Header = Instance.new("Frame", MainFrame); Header.Size = UDim2.new(1, 0, 0, 50); Header.BackgroundTransparency = 1
    local Title = Instance.new("TextLabel", Header); Title.Text = "  " .. (Config.Name or "GGH ROYAL"); Title.Size = UDim2.new(0.5, 0, 1, 0); Title.TextColor3 = Theme.Text; Title.BackgroundTransparency = 1; Title.Font = "GothamBold"; Title.TextSize = 16; Title.TextXAlignment = "Left"

    local function CreateTopBtn(text, pos, color)
        local b = Instance.new("TextButton", Header); b.Size = UDim2.new(0, 32, 0, 32); b.Position = pos; b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        b.Text = text; b.TextColor3 = color; b.Font = "GothamBold"; b.TextSize = 18; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
        return b
    end
    
    local CloseBtn = CreateTopBtn("×", UDim2.new(1, -42, 0.5, -16), Color3.fromRGB(255, 80, 80))
    local MinBtn = CreateTopBtn("-", UDim2.new(1, -82, 0.5, -16), Theme.Text)
    local SetBtn = CreateTopBtn("⚙", UDim2.new(1, -122, 0.5, -16), Theme.Accent)

    CloseBtn.MouseButton1Click:Connect(function() ConfirmFrame.Visible = true end)
    NoBtn.MouseButton1Click:Connect(function() ConfirmFrame.Visible = false end)
    YesBtn.MouseButton1Click:Connect(function() MainGui:Destroy() end)

    -- [ التابات ]
    local Sidebar = Instance.new("Frame", MainFrame); Sidebar.Size = UDim2.new(0, 160, 1, -70); Sidebar.Position = UDim2.new(0, 10, 0, 65); Sidebar.BackgroundTransparency = 1
    Instance.new("UIListLayout", Sidebar).Padding = UDim.new(0, 8)
    local Container = Instance.new("Frame", MainFrame); Container.Size = UDim2.new(1, -190, 1, -75); Container.Position = UDim2.new(0, 180, 0, 65); Container.BackgroundTransparency = 1

    local Tabs = {}
    function Tabs:CreateTab(Name)
        local Page = Instance.new("ScrollingFrame", Container); Page.Size = UDim2.new(1, 0, 1, 0); Page.Visible = false; Page.BackgroundTransparency = 1; Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 10)
        
        local TBtn = Instance.new("TextButton", Sidebar); TBtn.Size = UDim2.new(1, 0, 0, 48); TBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25); TBtn.Text = Name; TBtn.TextColor3 = Theme.Text; TBtn.Font = "GothamBold"; TBtn.TextSize = 15; Instance.new("UICorner", TBtn).CornerRadius = UDim.new(0, 10)
        
        TBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            Page.Visible = true
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.BackgroundColor3 = Color3.fromRGB(25, 25, 25) end end
            TBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        end)

        local Elements = {}
        function Elements:AddSlider(C)
            local s = Instance.new("Frame", Page); s.Size = UDim2.new(1, -10, 0, 60); s.BackgroundColor3 = Color3.fromRGB(22, 22, 22); Instance.new("UICorner", s).CornerRadius = UDim.new(0, 10)
            local t = Instance.new("TextLabel", s); t.Text = "  "..C.Name.." : "..C.Min; t.Size = UDim2.new(1, 0, 0, 30); t.TextColor3 = Theme.Text; t.BackgroundTransparency = 1; t.TextXAlignment = "Left"; t.Font = "GothamBold"
            local bar = Instance.new("Frame", s); bar.Size = UDim2.new(0.85, 0, 0, 6); bar.Position = UDim2.new(0.07, 0, 0.75, 0); bar.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Instance.new("UICorner", bar)
            local fill = Instance.new("Frame", bar); fill.Size = UDim2.new(0, 0, 1, 0); fill.BackgroundColor3 = Theme.Accent; Instance.new("UICorner", fill)
            local knob = Instance.new("Frame", fill); knob.Size = UDim2.new(0, 16, 0, 16); knob.Position = UDim2.new(1, -8, 0.5, -8); knob.BackgroundColor3 = Theme.Text; Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
            -- نظام السحب المطور للسلايدر
            local drag = false
            local function update()
                local p = math.clamp((game:GetService("Players").LocalPlayer:GetMouse().X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                fill.Size = UDim2.new(p, 0, 1, 0); local val = math.floor(C.Min + (C.Max - C.Min) * p)
                t.Text = "  "..C.Name.." : "..val; C.Callback(val)
            end
            bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
            game:GetService("RunService").RenderStepped:Connect(function() if drag then update() end end)
        end
        return Elements
    end
    return Tabs
end
return Lib
