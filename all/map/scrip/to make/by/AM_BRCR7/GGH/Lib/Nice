function GGH_Lib:InitKeySystem(config, callback)
	if not config.Enabled then callback() return end
	
	local Player = Players.LocalPlayer
	local InternalID = string.reverse(string.sub(Player.UserId .. "GGH", 1, 6))
	local MASTER_KEY = "AM_BRCR7_GGH_7"
	
	local KeyGui = Create("ScreenGui", {Parent = game.CoreGui, Name = "GGH_Auth"})
	local Main = Create("Frame", {Parent = KeyGui, Size = UDim2.new(0, 380, 0, 220), Position = UDim2.new(0.5, -190, 0.5, -110), BackgroundColor3 = Color3.fromRGB(15,15,15)}, 12)
	
	Create("TextLabel", {Parent = Main, Size = UDim2.new(1,0,0,60), Text = "GGH SECURITY LOGIN", TextColor3 = Color3.fromRGB(180,0,255), Font = Enum.Font.GothamBold, TextSize = 20, BackgroundTransparency = 1})
	
	local Input = Create("TextBox", {Parent = Main, Size = UDim2.new(0.8, 0, 0, 45), Position = UDim2.new(0.1, 0, 0.35, 0), PlaceholderText = "Enter Your Secret Key...", Text = "", BackgroundColor3 = Color3.fromRGB(25,25,25), TextColor3 = Color3.fromRGB(255,255,255), Font = Enum.Font.Gotham, TextSize = 14}, 8)
	local Submit = Create("TextButton", {Parent = Main, Size = UDim2.new(0.35, 0, 0, 40), Position = UDim2.new(0.1, 0, 0.7, 0), Text = "Verify", BackgroundColor3 = Color3.fromRGB(180,0,255), TextColor3 = Color3.fromRGB(255,255,255), Font = Enum.Font.GothamBold}, 8)
	local GetKey = Create("TextButton", {Parent = Main, Size = UDim2.new(0.35, 0, 0, 40), Position = UDim2.new(0.55, 0, 0.7, 0), Text = "Get Key", BackgroundColor3 = Color3.fromRGB(40,40,40), TextColor3 = Color3.fromRGB(255,255,255), Font = Enum.Font.GothamBold}, 8)
	
	Submit.MouseButton1Click:Connect(function()
		if Input.Text == MASTER_KEY or Input.Text == (InternalID .. config.SecretSuffix) then 
			KeyGui:Destroy() 
			callback()
		else 
			Input.Text = "" 
			Input.PlaceholderText = "WRONG KEY!" 
		end
	end)
	
	GetKey.MouseButton1Click:Connect(function() setclipboard(config.Link) end)
end

