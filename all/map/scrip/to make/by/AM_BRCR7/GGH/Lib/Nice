    MainTab:AddButton({ Name = "Speed", Callback = function() print("Fast!") end })
    MainTab:AddToggle({ Name = "AutoFarm", Callback = function(state) print(state) end })
    MainTab:AddSlider({ Name = "Power", Min = 0, Max = 100, Callback = function(v) print(v) end })
    
