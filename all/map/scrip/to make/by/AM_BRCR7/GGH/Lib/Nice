-- [[ AM_BRCR7 ULTIMATE LIBRARY V6.0 - ULTRA STABLE ]] --
local Library = {}
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")

local Themes = {
    ["Cyber"] = Color3.fromRGB(0, 255, 150),
    ["Hacker"] = Color3.fromRGB(0, 255, 0),
    ["Neon_Blue"] = Color3.fromRGB(0, 255, 255),
    ["Default"] = Color3.fromRGB(170, 0, 255)
}

function Library:CreateWindow(Settings)
    local MainColor = Themes[Settings.Theme] or Themes["Default"]
    local Name = Settings.Name or "AM_BRCR7 HUB"
    
    -- إنشاء الـ ScreenGui في الـ CoreGui لضمان الظهور
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "AM_BRCR7_UI"
    ScreenGui.Parent = game:GetService("CoreGui")
    ScreenGui.ResetOnSpawn = false
    ScreenGui.IgnoreGuiInset = true -- يخليها تظهر فوق كل شيء

    -- [1] الشعار العائم (الزر اللي يفتح السكربت)
    local FloatingBtn = Instance.new("ImageButton", ScreenGui)
    FloatingBtn.Size = UDim2.new(0, 50, 0, 50)
    FloatingBtn.Position = UDim2.new(0, 20, 0.5, 0)
    FloatingBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    FloatingBtn.Image = "rbxassetid://10734950309" -- أيقونة افتراضية
    Instance.new("UICorner", FloatingBtn).CornerRadius = UDim.new(1, 0)
    local FStroke = Instance.new("UIStroke", FloatingBtn)
    FStroke.Color = MainColor; FStroke.Thickness = 2

    -- [2] الإطار الرئيسي (النافذة)
    local Main = Instance.new("Frame", ScreenGui)
    Main.Name = "MainFrame"
    Main.Size = UDim2.new(0, 550, 0, 350)
    Main.Position = UDim2.new(0.5, -275, 0.5, -175)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Main.Visible = false -- تبدأ مخفية وتفتح بالضغط على الزر
    Main.ClipsDescendants = true
    Main.Active = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
    local MStroke = Instance.new("UIStroke", Main)
    MStroke.Color = MainColor; MStroke.Thickness = 1.5

    -- دالة الفتح والإغلاق (مصلحة)
    FloatingBtn.MouseButton1Click:Connect(function()
        Main.Visible = not Main.Visible
        print("UI Visibility: " .. tostring(Main.Visible))
    end)

    -- [3] الشريط العلوي (Title Bar) مع السحب
    local TopBar = Instance.new("Frame", Main)
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    
    local Title = Instance.new("TextLabel", TopBar)
    Title.Text = "  " .. Name
    Title.Size = UDim2.new(1, -40, 1, 0)
    Title.TextColor3 = Color3.new(1, 1, 1)
    Title.BackgroundTransparency = 1
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14

    local CloseBtn = Instance.new("TextButton", TopBar)
    CloseBtn.Text = "X"
    CloseBtn.Size = UDim2.new(0, 30, 0, 25)
    CloseBtn.Position = UDim2.new(1, -35, 0, 5)
    CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    CloseBtn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", CloseBtn)

    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    -- [4] القائمة الجانبية (Sidebar)
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 140, 1, -35)
    Sidebar.Position = UDim2.new(0, 0, 0, 35)
    Sidebar.BackgroundColor3 = Color3.fromRGB(12, 12, 12)

    local TabScroll = Instance.new("ScrollingFrame", Sidebar)
    TabScroll.Size = UDim2.new(1, 0, 1, -10)
    TabScroll.BackgroundTransparency = 1
    TabScroll.ScrollBarThickness = 0
    local TabList = Instance.new("UIListLayout", TabScroll)
    TabList.Padding = UDim.new(0, 5)

    -- [5] منطقة الصفحات
    local PagesContainer = Instance.new("Frame", Main)
    PagesContainer.Size = UDim2.new(1, -150, 1, -45)
    PagesContainer.Position = UDim2.new(0, 145, 0, 40)
    PagesContainer.BackgroundTransparency = 1

    local Window = {}

    function Window:CreateTab(TabName)
        local Page = Instance.new("ScrollingFrame", PagesContainer)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.Visible = false
        Page.BackgroundTransparency = 1
        Page.ScrollBarThickness = 2
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)
        
        local TabBtn = Instance.new("TextButton", TabScroll)
        TabBtn.Size = UDim2.new(1, -10, 0, 30)
        TabBtn.Text = TabName
        TabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        TabBtn.TextColor3 = Color3.new(1, 1, 1)
        Instance.new("UICorner", TabBtn)
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(PagesContainer:GetChildren()) do v.Visible = false end
            Page.Visible = true
        end)

        local Elements = {}
        function Elements:AddButton(C)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(1, -10, 0, 35); B.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            B.Text = C.Name; B.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", B)
            B.MouseButton1Click:Connect(C.Callback)
        end
        return Elements
    end
    
    print("✅ Library V6 Initialized Successfully!")
    return Window
end

return Library
