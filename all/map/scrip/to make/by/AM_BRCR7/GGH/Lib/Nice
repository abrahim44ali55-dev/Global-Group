    local Pages = Instance.new("Frame", Main); Pages.Size = UDim2.new(1, -170, 1, -50); Pages.Position = UDim2.new(0, 165, 0, 45); Pages.BackgroundTransparency = 1

    local Window = {}
    function Window:AddTabSection(Name)
        local ST = Instance.new("TextLabel", TabScroll); ST.Size = UDim2.new(1,-10,0,25); ST.Text = Name:upper(); ST.TextColor3 = MainColor; ST.BackgroundTransparency = 1; ST.TextXAlignment = 0; ST.Font = Enum.Font.GothamBold; ST.TextSize = 11; ST.TextTransparency = 0.4
    end

    function Window:CreateTab(Name)
        local Page = Instance.new("ScrollingFrame", Pages); Page.Size = UDim2.new(1,0,1,0); Page.Visible = false; Page.BackgroundTransparency = 1; Page.ScrollBarThickness = 0
