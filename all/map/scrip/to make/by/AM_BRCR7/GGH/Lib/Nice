            local In = Instance.new("Frame", Bx); In.Size = UDim2.new(0,16,0,16); In.Position = UDim2.new(0,2,0.5,-8); In.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", In).CornerRadius = UDim.new(1,0)
            local S = false; T.MouseButton1Click:Connect(function() S = not S; In:TweenPosition(S and UDim2.new(1,-18,0.5,-8) or UDim2.new(0,2,0.5,-8), "Out", "Quad", 0.2, true); Bx.BackgroundColor3 = S and MainColor or Color3.fromRGB(50,50,50); C.Callback(S) end)
