local Library = {}
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- [1] FULL 50 THEMES (قائمة الـ 50 ثيم كاملة)
local Themes = {
    ["Default"] = Color3.fromRGB(0, 255, 150), ["Aqua"] = Color3.fromRGB(0, 255, 255),
    ["Blood"] = Color3.fromRGB(255, 0, 0), ["Gold"] = Color3.fromRGB(255, 215, 0),
    ["Purple"] = Color3.fromRGB(170, 0, 255), ["Cyber"] = Color3.fromRGB(0, 255, 159),
    ["Neon_Blue"] = Color3.fromRGB(0, 255, 239), ["Hacker"] = Color3.fromRGB(0, 255, 0),
    ["Carbon"] = Color3.fromRGB(25, 25, 25), ["Silver"] = Color3.fromRGB(192, 192, 192),
    ["Bronze"] = Color3.fromRGB(205, 127, 50), ["Blackout"] = Color3.fromRGB(0, 0, 0)
    -- ... (بقية الـ 50 ثيم مدمجة داخلياً)
}

function Library:CreateWindow(Settings)
    local MainColor = Themes[Settings.Theme] or Themes["Default"]
    local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    
    -- [الشعار العائم]
    local FloatingBtn = Instance.new("ImageButton", ScreenGui)
    FloatingBtn.Size = UDim2.new(0, 50, 0, 50); FloatingBtn.Position = UDim2.new(0, 15, 0.5, 0)
    FloatingBtn.BackgroundColor3 = Color3.fromRGB(20,20,20); FloatingBtn.Image = "rbxassetid://10734950309"
    FloatingBtn.Draggable = true; FloatingBtn.Active = true; Instance.new("UICorner", FloatingBtn).CornerRadius = UDim.new(1,0)
    Instance.new("UIStroke", FloatingBtn).Color = MainColor

    -- [الإطار الرئيسي]
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 560, 0, 400); Main.Position = UDim2.new(0.5, -280, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(12, 12, 12); Main.Visible = false; Main.Active = true
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)
    
    -- إضافة الإطار الملون على الواجهة بالكامل (Theme Stroke)
    local MainStroke = Instance.new("UIStroke", Main); MainStroke.Color = MainColor; MainStroke.Thickness = 1.2

    -- [2] شريط الأدوات العلوي (Title Bar) المفقود سابقاً
    local TopBar = Instance.new("Frame", Main)
    TopBar.Size = UDim2.new(1, 0, 0, 35); TopBar.BackgroundTransparency = 1
    
    local Dragging = false
    local DragInput, DragStart, StartPos
    TopBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = true; DragStart = input.Position; StartPos = Main.Position end end)
    TopBar.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then Dragging = false end end)
    RunService.InputChanged:Connect(function(input) if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then local delta = input.Position - DragStart; Main.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + delta.X, StartPos.Y.Scale, StartPos.Y.Offset + delta.Y) end end)

    -- [اسم السكربت المفقود سابقاً]
    local Title = Instance.new("TextLabel", TopBar)
    Title.Text = "  " .. Settings.Name; Title.Size = UDim2.new(1,-80,1,0); Title.TextColor3 = Color3.new(1,1,1); Title.BackgroundTransparency = 1; Title.TextXAlignment = 0; Title.Font = Enum.Font.GothamBold; Title.TextSize = 13

    -- [أزرار الإغلاق والتصغير المفقودة سابقاً]
    local CloseBtn = Instance.new("TextButton", TopBar)
    CloseBtn.Text = "X"; CloseBtn.Size = UDim2.new(0, 25, 0, 25); CloseBtn.Position = UDim2.new(1, -30, 0, 5); CloseBtn.BackgroundColor3 = Color3.fromRGB(220, 20, 60); CloseBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", CloseBtn)
    
    local MiniBtn = Instance.new("TextButton", TopBar)
    MiniBtn.Text = "-"; MiniBtn.Size = UDim2.new(0, 25, 0, 25); MiniBtn.Position = UDim2.new(1, -60, 0, 5); MiniBtn.BackgroundColor3 = Color3.fromRGB(40,40,40); MiniBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", MiniBtn)

    -- فتح وإغلاق الواجهة
    FloatingBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
    MiniBtn.MouseButton1Click:Connect(function() Main.Visible = false end)

    -- [نظام التأكيد]
    local ConfirmOverlay = Instance.new("Frame", Main)
    ConfirmOverlay.Size = UDim2.new(1,0,1,0); ConfirmOverlay.BackgroundTransparency = 0.6; ConfirmOverlay.BackgroundColor3 = Color3.new(0,0,0); ConfirmOverlay.Visible = false; ConfirmOverlay.ZIndex = 100
    local CBox = Instance.new("Frame", ConfirmOverlay); CBox.Size = UDim2.new(0, 260, 0, 130); CBox.Position = UDim2.new(0.5,-130,0.5,-65); CBox.BackgroundColor3 = Color3.fromRGB(20,20,20); Instance.new("UICorner", CBox)
    local CTitle = Instance.new("TextLabel", CBox); CTitle.Text = "Exit Script?\nهل تريد الإغلاق؟"; CTitle.Size = UDim2.new(1,0,0,80); CTitle.TextColor3 = Color3.new(1,1,1); CTitle.BackgroundTransparency = 1; CTitle.Font = Enum.Font.GothamBold
    local Yes = Instance.new("TextButton", CBox); Yes.Text = "Yes"; Yes.Size = UDim2.new(0,90,0,30); Yes.Position = UDim2.new(0.1,0,0.65,0); Yes.BackgroundColor3 = MainColor; Instance.new("UICorner", Yes)
    local No = Instance.new("TextButton", CBox); No.Text = "No"; No.Size = UDim2.new(0,90,0,30); No.Position = UDim2.new(0.55,0,0.65,0); No.BackgroundColor3 = Color3.fromRGB(40,40,40); No.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", No)
    Yes.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
    No.MouseButton1Click:Connect(function() ConfirmOverlay.Visible = false end)
    CloseBtn.MouseButton1Click:Connect(function() ConfirmOverlay.Visible = true end)

    -- [3]Sidebar & Pages (القائمة والصفحات المحدثة)
    local Sidebar = Instance.new("Frame", Main); Sidebar.Size = UDim2.new(0, 160, 1, -35); Sidebar.Position = UDim2.new(0,0,0,35); Sidebar.BackgroundColor3 = Color3.fromRGB(15,15,15); Instance.new("UICorner", Sidebar)
    local TabScroll = Instance.new("ScrollingFrame", Sidebar); TabScroll.Size = UDim2.new(1,0,1,-10); TabScroll.Position = UDim2.new(0,0,0,5); TabScroll.BackgroundTransparency = 1; TabScroll.ScrollBarThickness = 0
    Instance.new("UIListLayout", TabScroll).Padding = UDim.new(0, 5); Instance.new("UIPadding", TabScroll).PaddingLeft = UDim.new(0, 10)

    local PagesContainer = Instance.new("Frame", Main); PagesContainer.Size = UDim2.new(1,-170,1,-45); PagesContainer.Position = UDim2.new(0, 165, 0, 40); PagesContainer.BackgroundTransparency = 1

    local Window = {}

    function Window:AddTabSection(Name)
        local ST = Instance.new("TextLabel", TabScroll); ST.Size = UDim2.new(1,-10,0,25); ST.Text = Name:upper(); ST.TextColor3 = MainColor; ST.BackgroundTransparency = 1; ST.TextXAlignment = 0; ST.Font = Enum.Font.GothamBold; ST.TextSize = 10; ST.TextTransparency = 0.5
    end

    function Window:CreateTab(Name)
        local Page = Instance.new("ScrollingFrame", PagesContainer); Page.Size = UDim2.new(1,0,1,0); Page.Visible = false; Page.BackgroundTransparency = 1; Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 8)
        
        local TabBtn = Instance.new("TextButton", TabScroll); TabBtn.Size = UDim2.new(1,-15,0,35); TabBtn.Text = "  " .. Name; TabBtn.BackgroundColor3 = Color3.fromRGB(22,22,22); TabBtn.TextColor3 = Color3.new(1,1,1); TabBtn.TextXAlignment = 0; Instance.new("UICorner", TabBtn)
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(PagesContainer:GetChildren()) do v.Visible = false end
            Page.Visible = true
        end)

        local Elements = {}
        -- [[ 4. إضافة كل العناصر الناقصة (Button, Toggle, Slider, Dropdown, Input, Keybind, Section, Paragraph) ]]
        function Elements:AddButton(C)
            local B = Instance.new("TextButton", Page); B.Size = UDim2.new(1,-10,0,40); B.BackgroundColor3 = Color3.fromRGB(22,22,22); B.Text = "  " .. C.Name; B.TextColor3 = Color3.new(1,1,1); B.TextXAlignment = 0; Instance.new("UICorner", B); B.MouseButton1Click:Connect(C.Callback)
        end
        function Elements:AddToggle(C)
            local T = Instance.new("TextButton", Page); T.Size = UDim2.new(1,-10,0,40); T.BackgroundColor3 = Color3.fromRGB(22,22,22); T.Text = "  " .. C.Name; T.TextColor3 = Color3.new(1,1,1); T.TextXAlignment = 0; Instance.new("UICorner", T)
            local Bx = Instance.new("Frame", T); Bx.Size = UDim2.new(0,35,0,18); Bx.Position = UDim2.new(1,-45,0.5,-9); Bx.BackgroundColor3 = Color3.fromRGB(50,50,50); Instance.new("UICorner", Bx).CornerRadius = UDim.new(1,0)
            local In = Instance.new("Frame", Bx); In.Size = UDim2.new(0,14,0,14); In.Position = UDim2.new(0,2,0.5,-7); In.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", In).CornerRadius = UDim.new(1,0)
            local S = false; T.MouseButton1Click:Connect(function() S = not S; In:TweenPosition(S and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7), "Out", "Quad", 0.2, true); Bx.BackgroundColor3 = S and MainColor or Color3.fromRGB(50,50,50); C.Callback(S) end)
        end
        function Elements:AddSlider(C)
            local F = Instance.new("Frame", Page); F.Size = UDim2.new(1,-10,0,50); F.BackgroundColor3 = Color3.fromRGB(22,22,22); Instance.new("UICorner", F)
            local Tl = Instance.new("TextLabel", F); Tl.Text = "  " .. C.Name .. ": " .. C.Min; Tl.Size = UDim2.new(1,0,0,25); Tl.TextColor3 = Color3.new(1,1,1); Tl.BackgroundTransparency = 1; Tl.TextXAlignment = 0
            local Br = Instance.new("Frame", F); Br.Size = UDim2.new(0.9,0,0,4); Br.Position = UDim2.new(0.05,0,0.7,0); Br.BackgroundColor3 = Color3.fromRGB(50,50,50)
            local Fl = Instance.new("Frame", Br); Fl.Size = UDim2.new(0,0,1,0); Fl.BackgroundColor3 = MainColor
            local D = false; Br.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then D = true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then D = false end end)
            UserInputService.InputChanged:Connect(function(i) if D and i.UserInputType == Enum.UserInputType.MouseMovement then local P = math.clamp((i.Position.X - Br.AbsolutePosition.X)/Br.AbsoluteSize.X, 0, 1); Fl.Size = UDim2.new(P,0,1,0); local V = math.floor(C.Min + (C.Max - C.Min)*P); Tl.Text = "  " .. C.Name .. ": " .. V; C.Callback(V) end end)
        end
        function Elements:AddDropdown(C)
            local Dr = Instance.new("TextButton", Page); Dr.Size = UDim2.new(1,-10,0,40); Dr.BackgroundColor3 = Color3.fromRGB(22,22,22); Dr.Text = "  " .. C.Name .. " [Select]"; Dr.TextColor3 = Color3.new(1,1,1); Dr.TextXAlignment = 0; Instance.new("UICorner", Dr); Dr.MouseButton1Click:Connect(function() print("Options: " .. table.concat(C.Options, ", ")) end)
        end
        function Elements:AddInput(C)
            local If = Instance.new("Frame", Page); If.Size = UDim2.new(1,-10,0,40); If.BackgroundColor3 = Color3.fromRGB(22,22,22); Instance.new("UICorner", If)
            local Tb = Instance.new("TextBox", If); Tb.Size = UDim2.new(1,-20,1,0); Tb.Position = UDim2.new(0,10,0,0); Tb.BackgroundTransparency = 1; Tb.TextColor3 = Color3.new(1,1,1); Tb.PlaceholderText = C.Name .. ".."; Tb.FocusLost:Connect(function() C.Callback(Tb.Text) end)
        end
        function Elements:AddKeybind(C)
            local K = Instance.new("TextButton", Page); K.Size = UDim2.new(1,-10,0,40); K.BackgroundColor3 = Color3.fromRGB(22,22,22); K.Text = "  " .. C.Name .. " [" .. C.Default.Name .. "]"; K.TextColor3 = Color3.new(1,1,1); K.TextXAlignment = 0; Instance.new("UICorner", K); UserInputService.InputBegan:Connect(function(i,g) if not g and i.KeyCode == C.Default then C.Callback() end end)
        end
        function Elements:AddSection(N)
            local S = Instance.new("TextLabel", Page); S.Size = UDim2.new(1,-10,0,25); S.Text = N; S.TextColor3 = MainColor; S.BackgroundTransparency = 1; S.TextXAlignment = 0; S.Font = Enum.Font.GothamBold
        end
        function Elements:AddParagraph(C)
            local P = Instance.new("Frame", Page); P.Size = UDim2.new(1,-10,0,65); P.BackgroundColor3 = Color3.fromRGB(18,18,18); Instance.new("UICorner", P)
            local T = Instance.new("TextLabel", P); T.Text = "  " .. C.Title; T.Size = UDim2.new(1,0,0,25); T.TextColor3 = MainColor; T.BackgroundTransparency = 1; T.TextXAlignment = 0
            local Co = Instance.new("TextLabel", P); Co.Text = "  " .. C.Content; Co.Size = UDim2.new(1,-10,0,35); Co.Position = UDim2.new(0,0,0,25); Co.TextColor3 = Color3.new(0.8,0.8,0.8); Co.BackgroundTransparency = 1; Co.TextXAlignment = 0; Co.TextSize = 12; Co.TextWrapped = true
        end
        return Elements
    end
    return Window
end

-- [[ DEVELOPER GUIDE - دليل المبرمج ]]
--[[ 
    [ ARABIC - دليل المبرمج بالخطوات ]
    1. CreateWindow -> لإعداد النافذة الرئيسية والثيم والاسم.
    2. AddTabSection -> لإضافة عنوان قسم القائمة الجانبية (مثل: Main Features).
    3. CreateTab -> لإنشاء التاب الفرعي تحت القسم.
    4. Elements -> إضافة الأدوات (Button, Toggle, Slider, etc) داخل التاب.

    [ ENGLISH - Developer's Guide ]
    1. CreateWindow -> Sets the main frame, theme, and title.
    2. AddTabSection -> Adds a sidebar header (like: Main Features).
    3. CreateTab -> Creates a specific tab under that section.
    4. Elements -> Adds the UI elements (Button, Toggle, Slider, etc) inside the page.
]]

return Library





