        TabBtn.MouseButton1Click:Connect(function() for _, v in pairs(Pages:GetChildren()) do v.Visible = false end Page.Visible = true end)

        local Elements = {}
        -- [Button]
        function Elements:AddButton(C)
            local B = Instance.new("TextButton", Page); B.Size = UDim2.new(1,-10,0,40); B.BackgroundColor3 = MainColor; B.Text = C.Name; B.TextColor3 = Color3.new(0,0,0); B.Font = Enum.Font.GothamBold; Instance.new("UICorner", B); B.MouseButton1Click:Connect(C.Callback)
        end
        -- [Toggle]
        function Elements:AddToggle(C)
            local T = Instance.new("TextButton", Page); T.Size = UDim2.new(1,-10,0,45); T.BackgroundColor3 = Color3.fromRGB(25,25,25); T.Text = "  "..C.Name; T.TextColor3 = Color3.new(1,1,1); T.TextXAlignment = 0; Instance.new("UICorner", T)
