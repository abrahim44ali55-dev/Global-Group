            local Fl = Instance.new("Frame", Br); Fl.Size = UDim2.new(0,0,1,0); Fl.BackgroundColor3 = MainColor; Instance.new("UICorner", Fl)
            local D = false; Br.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then D = true end end)
            UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then D = false end end)
            UIS.InputChanged:Connect(function(i) if D and i.UserInputType == Enum.UserInputType.MouseMovement then local P = math.clamp((i.Position.X - Br.AbsolutePosition.X)/Br.AbsoluteSize.X, 0, 1); Fl.Size = UDim2.new(P,0,1,0); local V = math.floor(C.Min + (C.Max-C.Min)*P); Tl.Text = "  "..C.Name..": "..V; C.Callback(V) end end)
        end
        -- [Input]
        function Elements:AddInput(C)
            local I = Instance.new("Frame", Page); I.Size = UDim2.new(1,-10,0,45); I.BackgroundColor3 = Color3.fromRGB(25,25,25); Instance.new("UICorner", I)
            local T = Instance.new("TextBox", I); T.Size = UDim2.new(1,-20,1,0); T.Position = UDim2.new(0,10,0,0); T.BackgroundTransparency = 1; T.TextColor3 = Color3.new(1,1,1); T.PlaceholderText = C.Name.."..."; T.Text = ""; T.FocusLost:Connect(function() C.Callback(T.Text) end)
