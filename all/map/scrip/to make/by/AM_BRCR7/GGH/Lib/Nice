            local Tl = Instance.new("TextLabel", F); Tl.Text = "  "..C.Name..": "..C.Min; Tl.Size = UDim2.new(1,0,0,30); Tl.TextColor3 = Color3.new(1,1,1); Tl.BackgroundTransparency = 1; Tl.TextXAlignment = 0
