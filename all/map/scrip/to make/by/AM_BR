-- وظائف التحديث المستمر (Noclip / Inf Jump)
game:GetService("RunService").Stepped:Connect(function()
    if _G.N and game.Players.LocalPlayer.Character then
        for _, p in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.I and game.Players.LocalPlayer.Character then
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

