-- التبويبات
local MainTab = Window:Tab({Title = "Main", Icon = "house"})
local SearchTab = Window:Tab({Title = "Search", Icon = "search"})
local SaveTab = Window:Tab({Title = "Save", Icon = "star"})
local ExecTab = Window:Tab({Title = "Executor", Icon = "code"})

local MainSection = MainTab:Section({Title = "Essential Tools"})

-- الأزرار والأدوات
MainSection:Button({Title = "Shift Lock", Callback = function() 
    loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Shift-Lock-121871"))() 
end})

MainSection:Toggle({Title = "Green ESP", Callback = function(v) 
    _G.E = v 
    task.spawn(function() 
        while _G.E do 
            for _, p in pairs(game.Players:GetPlayers()) do 
                if p ~= game.Players.LocalPlayer and p.Character then 
                    local h = p.Character:FindFirstChild("HighlightESP") or Instance.new("Highlight", p.Character) 
                    h.Name = "HighlightESP"; h.FillColor = Color3.fromRGB(0, 255, 0); h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
                end 
            end 
            task.wait(2) 
        end 
    end) 
end})

MainSection:Slider({Title = "Speed", Value = {Min = 16, Max = 500, Default = 16}, Callback = function(v) 
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v 
end})

MainSection:Slider({Title = "Jump", Value = {Min = 50, Max = 500, Default = 50}, Callback = function(v) 
    game.Players.LocalPlayer.Character.Humanoid.UseJumpPower = true
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = v 
end})

MainSection:Toggle({Title = "Noclip", Callback = function(v) _G.N = v end})
MainSection:Toggle({Title = "Inf Jump", Callback = function(v) _G.I = v end})

MainSection:Button({Title = "Fast Mode (FPS)", Callback = function() 
    for _, v in pairs(game:GetDescendants()) do 
        if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic 
        elseif v:IsA("Texture") then v:Destroy() end 
    end 
end})

MainSection:Button({Title = "Fly GUI", Callback = function() 
    loadstring(game:HttpGet("https://raw.githubusercontent.com/XNEOFF/FlyGuiV3/main/FlyGuiV3.txt"))() 
end})

